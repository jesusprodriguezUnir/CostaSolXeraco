---
const links = [
    { label: 'Inicio', href: '/' },
    { label: 'Ventas', href: '/ventas' },
    { label: 'Alquileres', href: 'https://www.serviplaya.com/' },
    { label: 'Webcam 🔴', href: '/webcam' },
    { label: 'Experiencia Xeraco', href: '/experiencia' },
];
---

<header class="fixed w-full z-50 glass-panel py-4 transition-all duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center">
            <!-- Logo -->
            <a href="/" class="flex flex-col items-start group">
                <span class="text-2xl font-serif font-bold text-primary-900 group-hover:text-primary-600 transition-colors">CostaSol</span>
                <span class="text-sm font-semibold text-secondary-600 tracking-widest uppercase">Xeraco</span>
            </a>

            <!-- Desktop Navigation -->
            <nav class="hidden md:flex items-center space-x-8">
                {links.map(link => (
                    <a 
                        href={link.href}
                        target={link.label === 'Alquileres' ? '_blank' : '_self'}
                        class={`text-sm font-medium transition-colors hover:text-primary-600 ${
                            link.label.includes('Webcam') 
                                ? 'text-red-600 font-bold animate-pulse hover:text-red-700' 
                                : 'text-slate-700'
                        }`}
                    >
                        {link.label}
                    </a>
                ))}
                
                <a href="#contacto" class="bg-primary-600 hover:bg-primary-700 text-white px-6 py-2.5 rounded-full font-medium transition-all shadow-md hover:shadow-lg transform hover:-translate-y-0.5">
                    Hablamos
                </a>
            </nav>

            <!-- Mobile menu button -->
            <button class="md:hidden p-2 text-primary-900">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>
        </div>
    </div>
</header>
