---
interface Props {
  property: {
    id: string;
    title: string;
    location: string;
    price: string;
    specs: string[];
    amenities: string[];
    localImages: string[];
  };
}

const { property } = Astro.props;
const mainImage = property.localImages?.[0] || 'https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&q=80&w=2070';
const baseUrl = import.meta.env.BASE_URL;
const imageSrc = mainImage.startsWith('http') ? mainImage : `${baseUrl}${mainImage}`;
---

<article class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-slate-100 flex flex-col h-full transform hover:-translate-y-1">
    <div class="relative overflow-hidden aspect-[4/3]">
        <img 
            src={imageSrc} 
            alt={property.title} 
            class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-700 ease-in-out"
            loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 to-transparent opacity-80"></div>
        
        <div class="absolute bottom-4 left-4 right-4 flex justify-between items-end">
            <div>
                <h3 class="text-white font-serif font-bold text-xl drop-shadow-md leading-tight">{property.title}</h3>
                <p class="text-slate-200 text-sm font-medium flex items-center gap-1 mt-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    {property.location}
                </p>
            </div>
            <div class="bg-primary-600/90 backdrop-blur-sm text-white px-3 py-1.5 rounded-lg font-bold shadow-lg">
                {property.price}
            </div>
        </div>
    </div>

    <!-- Details section -->
    <div class="p-5 flex flex-col flex-grow">
        <!-- Specs -->
        <div class="flex flex-wrap gap-2 mb-4">
            {property.specs.map(spec => (
                <span class="bg-slate-50 text-slate-600 border border-slate-100 px-2 py-1 rounded text-xs font-semibold">
                    {spec}
                </span>
            ))}
        </div>

        <!-- Amenities -->
        {property.amenities.length > 0 && (
            <div class="flex gap-3 text-slate-500 text-sm mt-auto mb-5">
                {property.amenities.includes('Piscina') && (
                    <span class="flex items-center gap-1" title="Piscina">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                           <path d="M22 17c-2 0-3-1-4-2s-2-2-4-2-3 1-4 2-2 2-4 2-3-1-4-2"></path>
                           <path d="M22 22c-2 0-3-1-4-2s-2-2-4-2-3 1-4 2-2 2-4 2-3-1-4-2"></path>
                           <path d="M12 10v4M8 10v4M16 10v4"></path>
                        </svg>
                        Piscina
                    </span>
                )}
                {property.amenities.includes('Garaje') && (
                    <span class="flex items-center gap-1" title="Garaje">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
                        </svg>
                        Garaje
                    </span>
                )}
                 {property.amenities.includes('Ascensor') && (
                    <span class="flex items-center gap-1" title="Ascensor">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l4-4 4 4m0 6l-4 4-4-4" />
                        </svg>
                        Ascensor
                    </span>
                )}
            </div>
        )}

        <!-- Action Button -->
        <a href={`${baseUrl}propiedad/${property.id}`} class="mt-auto block w-full text-center bg-slate-50 hover:bg-primary-50 text-primary-700 font-semibold py-2.5 rounded-xl border border-primary-100 hover:border-primary-300 transition-colors">
            Ver detalles
        </a>
    </div>
</article>
