---
import Layout from '../layouts/Layout.astro';
---

<Layout 
    title="Contacto | CostaSol Xeraco" 
    description="Contacta con CostaSol Xeraco para informarte sobre ventas o alquileres de apartamentos en la playa. Oficinas en Av. Mota."
>
    <!-- Background Header -->
    <div class="pt-32 pb-16 bg-gradient-to-br from-primary-900 to-primary-800 border-b border-primary-700 relative overflow-hidden">
        <div class="absolute inset-0 opacity-10">
            <svg class="h-full w-full" xmlns="http://www.w3.org/2000/svg"><defs><pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M 40 0 L 0 0 0 40" fill="none" stroke="currentColor" stroke-width="1"/></pattern></defs><rect width="100%" height="100%" fill="url(#grid)"/></svg>
        </div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
            <span class="text-secondary-400 font-bold tracking-widest uppercase text-sm mb-4 block">Hablamos</span>
            <h1 class="text-4xl md:text-5xl font-serif font-bold text-white mb-6 leading-tight">Contacto Directo</h1>
            <p class="text-primary-100 max-w-2xl mx-auto text-lg">
                ¿Buscas vender, comprar o tienes dudas sobre una reserva? Nuestro equipo local te atenderá personalmente.
            </p>
        </div>
    </div>

    <!-- Contact Grid -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 -mt-10 relative z-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 bg-white rounded-3xl shadow-xl border border-slate-100 overflow-hidden">
            
            <!-- Left col: Form -->
            <div class="p-8 md:p-12 lg:p-16">
                <h2 class="text-2xl font-serif font-bold text-slate-900 mb-2">Envíanos un mensaje</h2>
                <p class="text-slate-500 mb-8">Rellena el formulario y te responderemos en menos de 24 horas laborables.</p>
                
                <!-- IMPORTANTE: Sustituir XXXXXXX por el ID de Formspree real si se usara. Actualmente es un form dummy funcional para la vista. -->
                <form action="https://formspree.io/f/dummy" method="POST" class="space-y-6">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div>
                            <label for="name" class="block text-sm font-medium text-slate-700 mb-2">Nombre completo</label>
                            <input type="text" name="name" id="name" required class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary-500 transition-shadow">
                        </div>
                        <div>
                            <label for="email" class="block text-sm font-medium text-slate-700 mb-2">Correo electrónico</label>
                            <input type="email" name="email" id="email" required class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary-500 transition-shadow">
                        </div>
                    </div>

                    <div>
                        <label for="subject" class="block text-sm font-medium text-slate-700 mb-2">Asunto</label>
                        <select id="subject" name="_subject" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary-500 transition-shadow text-slate-700">
                            <option value="Información sobre Inmueble en Venta">Estoy interesado en una Propiedad (Venta)</option>
                            <option value="Información sobre Alquiler Vacacional">Tengo una duda sobre Alquiler Vacacional</option>
                            <option value="Quiero vender o alquilar mi apartamento">Quiero que gestionéis mi apartamento</option>
                            <option value="Otra consulta genérica">Otra consulta</option>
                        </select>
                    </div>

                    <div>
                        <label for="message" class="block text-sm font-medium text-slate-700 mb-2">Mensaje</label>
                        <textarea id="message" name="message" rows="5" required class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary-500 transition-shadow resize-none" placeholder="¿En qué podemos ayudarte?"></textarea>
                    </div>

                    <!-- Redirección silenciosa requerida por Formspree -->
                    <input type="hidden" name="_next" value="http://localhost:4321/contacto?success=1">

                    <button type="submit" class="w-full bg-primary-600 hover:bg-primary-700 text-white font-bold py-4 rounded-xl transition-all shadow-[0_0_20px_rgba(20,184,166,0.2)] hover:shadow-[0_0_30px_rgba(20,184,166,0.4)]">
                        Enviar Consulta
                    </button>
                    <p class="text-xs text-slate-400 text-center mt-4">Al enviar este formulario aceptas nuestra política de privacidad.</p>
                </form>
            </div>

            <!-- Right col: Map & Info -->
            <div class="bg-slate-50 relative">
                <!-- Google Maps iFrame -->
                <div class="absolute inset-0 z-0 h-full">
                    <iframe 
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1558.4682337624734!2d-0.194488390885145!3d39.04639414445885!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd61e1b12b5cbac5%3A0xe7a5c78f1fc3addd!2sAv.%20Mota%2C%2046730%20Platja%20de%20Xeraco%2C%20Valencia!5e0!3m2!1ses!2ses!4v1700000000000!5m2!1ses!2ses" 
                        class="w-full h-full border-0 grayscale opacity-90 contrast-125" 
                        allowfullscreen="" 
                        loading="lazy" 
                        referrerpolicy="no-referrer-when-downgrade">
                    </iframe>
                </div>
                
                <!-- Overlaid Info Box -->
                <div class="absolute bottom-8 left-8 right-8 bg-white/95 backdrop-blur-md p-8 rounded-2xl shadow-xl z-10 border border-white">
                    <h3 class="font-serif font-bold text-2xl text-slate-900 mb-6 flex items-center gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                        Oficina Central
                    </h3>
                    
                    <ul class="space-y-4">
                        <li class="flex items-start gap-4 text-slate-600">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                            <div>
                                <strong class="block text-slate-900">Dirección</strong>
                                Avenida de la Mota s/n<br/>
                                46730 Playa de Xeraco, Valencia
                            </div>
                        </li>
                        <li class="flex items-center gap-4 text-slate-600">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                            <div>
                                <strong class="block text-slate-900">Teléfono</strong>
                                <a href="tel:+34962892000" class="hover:text-primary-600 transition-colors">+34 96 289 20 00</a>
                            </div>
                        </li>
                        <li class="flex items-center gap-4 text-slate-600">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                            <div>
                                <strong class="block text-slate-900">Email</strong>
                                <a href="mailto:info@costasolxeraco.com" class="hover:text-primary-600 transition-colors">info@costasolxeraco.com</a>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>

        </div>
    </main>
</Layout>
