---
import Layout from '../layouts/Layout.astro';
import PropertyCard from '../components/PropertyCard.astro';
import propertiesData from '../data/propiedades.json';
---

<Layout 
    title="Propiedades en Venta | CostaSol Xeraco" 
    description="Encuentra apartamentos, chalets y estudios en venta en la Playa de Xeraco y Gandía."
>
    <!-- Header Spacing -->
    <div class="pt-24 pb-12 bg-slate-50 border-b border-slate-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h1 class="text-4xl md:text-5xl font-serif font-bold text-primary-900 mb-4">
                Propiedades en Venta
            </h1>
            <p class="text-lg text-slate-600 max-w-3xl">
                Explora el inventario completo de inmuebles disponibles. Tu nuevo rincón en el Mediterráneo te está esperando.
            </p>
        </div>
    </div>

    <!-- Filtros Interactivos -->
    <div class="bg-white border-b border-slate-200 sticky top-[72px] z-40 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
            <div class="flex flex-wrap gap-4 items-center">
                <span class="text-sm font-semibold text-slate-400 uppercase tracking-widest mr-2">Filtros:</span>
                <select id="filter-location" class="bg-slate-50 border border-slate-200 text-slate-700 py-2 px-4 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 cursor-pointer transition-colors">
                    <option value="all">Cualquier Localidad</option>
                    <option value="Playa de Xeraco">Playa de Xeraco</option>
                    <option value="Pueblo de Xeraco">Pueblo de Xeraco</option>
                    <option value="Playa de Gandía">Playa de Gandía</option>
                    <option value="Grao de Gandía">Grao de Gandía</option>
                </select>
                <select id="filter-type" class="bg-slate-50 border border-slate-200 text-slate-700 py-2 px-4 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 cursor-pointer transition-colors">
                    <option value="all">Cualquier Tipo</option>
                    <option value="Apartamento">Apartamento</option>
                    <option value="Casa de Pueblo">Casa de Pueblo</option>
                    <option value="Ático">Ático</option>
                    <option value="Bungalow">Bungalow</option>
                    <option value="Local Comercial">Local Comercial</option>
                    <option value="Parking">Parking</option>
                </select>
                <button id="filter-clear" class="bg-primary-50 text-primary-700 px-4 py-2 rounded-lg font-medium hover:bg-primary-100 transition-colors hidden sm:block">
                    Limpiar
                </button>
                <div class="ml-auto text-sm text-slate-500 font-medium whitespace-nowrap">
                    <span id="results-count">{propertiesData.length}</span> resultados
                </div>
            </div>
        </div>
    </div>

    <!-- Grid Properties -->
    <section class="py-12 bg-slate-50 min-h-[50vh]">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                {propertiesData.map(property => (
                    <PropertyCard property={property} />
                ))}
            </div>

            <!-- Divisor State Vacio -->
            <div id="empty-state" class="hidden text-center py-20 flex-col items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-slate-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                </svg>
                <h3 class="text-xl font-bold text-slate-700 mb-2">No se encontraron propiedades</h3>
                <p class="text-slate-500">Intenta probar con una combinación de filtros diferente.</p>
                <button onclick="document.getElementById('filter-clear').click()" class="mt-4 text-primary-600 font-medium hover:text-primary-800 underline">Borrar filtros</button>
            </div>
        </div>
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const locFilter = document.getElementById('filter-location') as HTMLSelectElement;
            const typeFilter = document.getElementById('filter-type') as HTMLSelectElement;
            const clearBtn = document.getElementById('filter-clear');
            const countEl = document.getElementById('results-count');
            const emptyState = document.getElementById('empty-state');
            const cards = document.querySelectorAll('.property-card') as NodeListOf<HTMLElement>;

            function filterCards() {
                const locVal = locFilter.value;
                const typeVal = typeFilter.value;
                let visibleFiles = 0;

                cards.forEach(card => {
                    const cardLoc = card.dataset.location;
                    const cardType = card.dataset.type;

                    const matchLoc = (locVal === 'all' || cardLoc === locVal);
                    const matchType = (typeVal === 'all' || cardType === typeVal);

                    if (matchLoc && matchType) {
                        card.style.display = 'flex';
                        visibleFiles++;
                    } else {
                        card.style.display = 'none';
                    }
                });

                if (countEl) countEl.textContent = visibleFiles.toString();
                
                if (emptyState) {
                    if (visibleFiles === 0) {
                        emptyState.style.display = 'flex';
                    } else {
                        emptyState.style.display = 'none';
                    }
                }
            }

            locFilter?.addEventListener('change', filterCards);
            typeFilter?.addEventListener('change', filterCards);

            clearBtn?.addEventListener('click', () => {
                if (locFilter) locFilter.value = 'all';
                if (typeFilter) typeFilter.value = 'all';
                filterCards();
            });
        });
    </script>
</Layout>
